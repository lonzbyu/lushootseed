      <body>
          <l n="1">
              <app>
                  <rdg wit="#Ch">Veni Sancte Spiritus:</rdg>
                  <rdg wit="#CBL">Veni Sancte Spiritus:</rdg>
              </app></l>
            
          <l n="2">
              <app>
                  <rdg wit="#Ch">Ō Shěrk-Sĭām!</rdg>
                  <rdg wit="#CBL"> ʔu šəq siʔab!</rdg>
          </app></l>
            
          <l n="3">
              <app>
                  <rdg wit="#Ch"> 'atlha twal Debālh,</rdg>
                  <rdg wit="#CBL">ʔ̌əƛ'a dxʷʔal dibəɬ</rdg>
              </app></l>
            
          <l n="4">
              <app>
                  <rdg wit="#Ch">ūĭŭd tsok tegwalh Debalh rach.</rdg>
                  <rdg wit="#CBL">huyud cəkʼʷ ti gʷəɬ dibəɬ x̌əč,</rdg>
              </app></l>
            
          <l n="5">
              <app>
                  <rdg wit="#Ch"> ōshăbětūbŭlh Debalh assilhtamerh,</rdg>
                  <rdg wit="#CBL">ʔušəbitubuɬ dibəɬ ʔaciɬtalbixʷ </rdg>
              </app></l>
            
          <l n="6">
              <app>
                  <rdg wit="#Ch"> Ămchĭ-tobolh ata adsgwa adrach twal debalh,</rdg>
                  <rdg wit="#CBL"> ʔabč'itubuɬ ʔə t(i) adsgʷaʔ adx̌əč dxʷʔal dibəɬ,</rdg>
              </app></l>
            
          <l n="7">
              <app>
                  <rdg wit="#Ch"> oyod tsok tesuyayus chelh. </rdg>
                  <rdg wit="#CBL">huyud cəkʼʷ tə suyayusčəɬ. </rdg>
              </app></l>
          
          <l n="8">
              <app>
                  <rdg wit="#Ch"> Klob assista!</rdg>
                  <rdg wit="#CBL">ƛ'ub ʔəsʔistəʔ.</rdg>
              </app></l>

    </body>
