    <text>
        <front>
            <div>
                <listWit>
                    <witness xml:id="Ch">Chirouse</witness>
                    <witness xml:id="CBL">Chirouse -- Bates and Lonsdale</witness>
                </listWit>
            </div>
            
        </front>
        <body>
            <l n="1">
                <app>
                    <rdg wit="#Ch">Hail Mary:</rdg>
                    <rdg wit="#CBL">Hail Mary:</rdg>
                </app></l>
            
            <l n="2">
                <app>
                    <rdg wit="#Ch"> O Tsī-Tsīam Maly,</rdg>
                    <rdg wit="#CBL">ʔu tsi siʔab Mali,</rdg>
                </app></l>
            
            <l n="3">
                <app>
                    <rdg wit="#Ch">āslěch ak gwalh Sherk tōsābĭětems</rdg>
                    <rdg wit="#CBL">ʔəsləč ʔə kʷi gʷəɬ šəq tusʔabyitəbs</rdg>
                </app></l>
            
            <l n="4">
                <app>
                    <rdg wit="#Ch"> ăā al degwe kwi Sherhk-Siam</rdg>
                    <rdg wit="#CBL"> ʔa ʔal dəgʷi kʷi šəq siʔab</rdg>
                </app></l>
            
            <l n="5">
                <app>
                    <rdg wit="#Ch">děgwě ktoshēklētem lilzirh walh twal mok tlhādāĭ, </rdg>
                    <rdg wit="#CBL"> dəgʷi kʷi tušiƛ'itəb (or tuhikʷitəb?) liɬʤixʷ haʔɬ dxʷʔal bəkʼʷ sɬadəyʔ,</rdg>
                </app></l>
            
            <l n="6">
                <app>
                    <rdg wit="#Ch">to shěklētem tadsgwa adbědā Jesu! </rdg>
                    <rdg wit="#CBL"> tušiƛ'itəb (or tuhikʷitəb?) t(i) adsgʷaʔ adbədaʔ Shesu.</rdg>
                </app></l>
            
            <l n="7">
                <app>
                    <rdg wit="#Ch"> Sainte Maly skōīăk Sherk Sĭam, </rdg>
                    <rdg wit="#CBL"> Sent-Mari skʼʷuy ʔə kʷi šəq siʔab </rdg>
                </app></l>
            
            <l n="8">
                <app>
                    <rdg wit="#Ch"> klob chorh otēēch ăltē twăl dē Shěkh Siām twălh dēbălh sā āssĭlhtăměrh,</rdg>
                    <rdg wit="#CBL"> ƛ'ub čəxʷ ʔut'iwiɬ ʔal ti dxʷʔal diʔ šəq siʔab dxʷʔal dibəɬ saʔ ʔaciɬtalbixʷ,</rdg>
                </app></l>
            
            <l n="9">
                <app>
                    <rdg wit="#Ch">ōĭ chŏr pōttlhěmătēēch twal kwe tlos atbechelh.</rdg>
                    <rdg wit="#CBL">huy čəxʷ put ɬəbət'iwiɬ dxʷʔal kʷi ɬusʔatəbəd čəɬ.</rdg>
                </app></l>
            
            <l n="10">
                <app>
                    <rdg wit="#Ch"> Klōb āssĭstă! </rdg>
                    <rdg wit="#CBL"> ƛ'ub ʔəsʔistəʔ!</rdg>
                </app></l>
  
        </body>
    </text>
</TEI>