    <text>
        <front>
            <div>
                <listWit>
                    <witness xml:id="Ch">Chirouse</witness>
                    <witness xml:id="CBL">Chirouse -- Bates and Lonsdale</witness>
                </listWit>
            </div>
            
            <!-- 
                From http://www.fisheaters.com/prayers.html#faith:
                O my God! 
                I love Thee above all things, with my whole heart and soul, 
                because Thou art all-good and worthy of all love. 
                I love my neighbor as myself for the love of Thee. 
                I forgive all who have injured me, 
                and ask pardon of all whom I have injured.
                -->
            
        </front>
        <body>
            <l n="1">
                <app>
                    <rdg wit="#Ch">An act of Charity.</rdg>
                    <rdg wit="#CBL">An act of Charity.</rdg>
                </app></l>
            
            <l n="2">
                <app>
                    <rdg wit="#Ch"> Gwalh Charite siayus: </rdg>
                    <rdg wit="#CBL">gʷəɬ charite syayus: </rdg>
                </app></l>
            
            <l n="3">
                <app>
                    <rdg wit="#Ch">O Sherk Siam dayāĭ chorh degwe skwakhed alh!</rdg>
                    <rdg wit="#CBL"> ʔu šəq siʔab dayʼayʼ čəxʷ dəgʷi ckʼʷaqid haʔɬ! </rdg>
                </app></l>
            
            <l n="4">
                <app>
                    <rdg wit="#Ch"> Dayāĭ chorh degwe skwākhed āssěkwăbābduh </rdg>
                    <rdg wit="#CBL"> dayʼayʼ čəxʷ dəgʷi ckʼʷaqid ʔəshikʷəbabdxʷ</rdg>
                </app></l>
            
            <l n="5">
                <app>
                    <rdg wit="#Ch"> Delh sorhrhatleldobetsid te degwe tolalde mok derach, </rdg>
                    <rdg wit="#CBL">diɬ cəxʷx̌aƛ'ildubicid tə dəgʷi tulʼʔal diʔ bəkʼʷ dx̌əč.</rdg>
                </app></l>
            
            <l n="6">
                <app>
                    <rdg wit="#Ch"> klalbassista twal tas'srhatledobetsid te degwe </rdg>
                    <rdg wit="#CBL"> ƛ'əlbəʔəsʔistəʔ dxʷʔal ta sʔəsx̌aƛ'ildubicid ta dəgʷi</rdg>
                </app></l>
            
            <l n="7">
                <app>
                    <rdg wit="#Ch"> tsarhatledobetsid kmok assilhtamur (?)ulum tes srhatlebut te tsa. </rdg>
                    <rdg wit="#CBL"> dsx̌aƛ'ildubicid kʷi bəkʼʷ ʔaciɬtalbixʷ, x̌ʷulʼab dsx̌aƛ'əbut tə ʔəca.</rdg>
                </app></l>
            
            <l n="8">
                <app>
                    <rdg wit="#Ch"> Klob assista! </rdg>
                    <rdg wit="#CBL"> ƛ'ub ʔəsʔistəʔ.</rdg>
                </app></l>
  
        </body>
    </text>
