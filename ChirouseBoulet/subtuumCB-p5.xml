    <text>
        <front>
            <div>
                <listWit>
                    <witness xml:id="Ch">Chirouse</witness>
                    <witness xml:id="CBL">Chirouse -- Bates and Lonsdale</witness>
                </listWit>
            </div>
            
            <!-- 
                From Wikipedia:
                
                Beneath your compassion, 
                We take refuge, O Mother of God: 
                do not despise our petitions in time of trouble: 
                but rescue us from dangers, 
                only pure, only blessed one. 
                -->
            
        </front>
        <body>
            <l n="1">
                <app>
                    <rdg wit="#Ch">sub tuum praesidium</rdg>
                    <rdg wit="#CBL">The sub tuum praesidium: ending all prayers</rdg>
                </app></l>
            
            <l n="2">
                <app>
                    <rdg wit="#Ch"> Ô Maly </rdg>
                    <rdg wit="#CBL"> O Mali </rdg>
                </app></l>
            
            <l n="3">
                <app>
                    <rdg wit="#Ch">Alh chorh dugwe,</rdg>
                    <rdg wit="#CBL"> haʔɬ  čəxʷ dəgʷi</rdg>
                </app></l>
            
            <l n="4">
                <app>
                    <rdg wit="#Ch">gwalh Sherh Skōĭ degwe, </rdg>
                    <rdg wit="#CBL"> gʷəɬ šəq skʼʷuy dəgʷi</rdg>
                </app></l>
            
            <l n="5">
                <app>
                    <rdg wit="#Ch"> ŏābiuchelh te degwe a te rachelh </rdg>
                    <rdg wit="#CBL"> ʔuʔabyicčəɬ ti dəgʷi ʔə ti x̌əččəɬ,</rdg>
                </app></l>
            
            <l n="6">
                <app>
                    <rdg wit="#Ch"> wē churh la rwamtis skudesutch(?) </rdg>
                    <rdg wit="#CBL"> xʷiʔ čəxʷ ləqʼʷux̌ʷub ti ???</rdg>
                </app></l>
            
            <l n="7">
                <app>
                    <rdg wit="#Ch"> skwaked chorh tlholarhrotobolh tolal tasdoku.</rdg>
                    <rdg wit="#CBL"> ckʼʷaqid čəxʷ ɬuləqəkʼʷutubuɬ tulʼʔal t(i) ʔəsdukʷ.</rdg>
                </app></l>
            
            <l n="8">
                <app>
                    <rdg wit="#Ch"> Klob assista.</rdg>
                    <rdg wit="#CBL"> ƛ'ub ʔəsʔistəʔ.</rdg>
                </app></l>
  
        </body>
    </text>
</TEI>