    <text>
        <front>
            <div>
                <listWit>
                    <witness xml:id="Ch">Chirouse</witness>
                    <witness xml:id="Bo">Boulet</witness>
                    <witness xml:id="LB">Bates and Lonsdale</witness>
                    <witness xml:id="XCBL">Chirouse -- Bates and Lonsdale</witness>
                </listWit>
            </div>
            
        </front>
        <body>
            <l n="1">
                <app>
                    <rdg wit="#Ch">The Sign of the Cross:</rdg>
                    <rdg wit="#Bo">SIGN OF THE CROSS.</rdg>                  
                    <rdg wit="#LB">SIGN OF THE CROSS.</rdg>
                    <rdg wit="#XCBL">The Sign of the Cross:</rdg>
                </app></l>
            
            <l n="2">
                <app>
                    <rdg wit="#Ch">Tawal ksnā ak Ban, ētă ā Beda, eta ā St. Esprit.</rdg>
                    <rdg wit="#Bo">Dhual ksda aku Ban, eta Bedas, eta Sent-Ospli.</rdg>                  
                    <rdg wit="#LB">dxʷʔal kʷi sdaʔ ʔə kʷi bad, ʔi tə bədaʔs, ʔi tə Sent-Ospli.</rdg>
                    <rdg wit="#XCBL">dxʷʔal kʷi sdaʔ ʔə kʷi bad, ʔi tiʔəʔ bədaʔ, ʔi tiʔəʔ Sent-Ospli.</rdg>
                </app></l>
            
            <l n="3">
                <app>
                    <rdg wit="#Ch"> Klob assista. </rdg>
                    <rdg wit="#Bo"> 'Tlob asista. </rdg>
                    <rdg wit="#LB"> ƛ'ub ʔəsʔistəʔ.</rdg>
                    <rdg wit="#XCBL"> ƛ'ub ʔəsʔistəʔ.</rdg>
                </app></l>
            
        </body>
    </text>
